# =============================================================
# LabHero — Variables de entorno
# Copia este fichero a .env y ajusta los valores
# =============================================================

COMPOSE_PROJECT_NAME=labhero

# Puerto en el que escucha Nginx en el host
LABHERO_HTTP_PORT=8081

# Nombres de los contenedores Docker
NGINX_CONTAINER_NAME=labhero-web
UPLOADER_CONTAINER_NAME=labhero-uploader
VIDEO_OPTIMIZER_CONTAINER_NAME=labhero-video-optimizer

# Zona horaria
TZ=Europe/Madrid

# Tamaño máximo de upload en MB
MAX_UPLOAD_MB=10

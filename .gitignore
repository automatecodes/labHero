# =============================================================
# LabHero — .gitignore
# =============================================================

# ── Configuración de entorno (sensible / local) ──────────────
.env
.env.local
.env.*.local

# ── Media: vídeos (binarios grandes, no versionar) ───────────
html/media/*.mp4
html/media/*.webm
html/media/*.mov
html/media/*.m4v
html/media/*.ogv
html/media/*.avi
html/media/*.mkv

# ── Media: logos generados en runtime por el uploader ────────
html/media/logo-current.*
html/media/image-logo-current.*
html/media/logo.json
html/media/image-logo.json

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyw
*.pyz
.Python
*.egg-info/
*.egg
.eggs/
dist/
build/
.cache/
pip-log.txt
pip-delete-this-directory.txt

# ── Entornos virtuales Python ─────────────────────────────────
venv/
.venv/
env/
ENV/
.env/

# ── Node (si se añade tooling frontend) ──────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.yarn/cache
.yarn/unplugged

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
*.log.*

# ── Sistema operativo ─────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ── Editores e IDEs ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.bak
.project
.classpath
.settings/

# ── Docker (artefactos locales) ───────────────────────────────
.docker/

# ── Backups y versiones antiguas ─────────────────────────────
old/
*.backup
*.orig

# ── Fichero duplicado de compose ─────────────────────────────
docker.compose.yml

# ── Temporales generados por herramientas ────────────────────
*.tmp
*.temp
.temp/
.tmp/
